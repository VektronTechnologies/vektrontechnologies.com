# VEKTRON Technologies — Cloudflare Pages security headers
# Applied to every response served from vektrontechnologies.com.
# Reference: https://developers.cloudflare.com/pages/configuration/headers/

/*
  # --- Transport & framing ---
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin

  # --- Permissions: lock down powerful APIs the marketing site never uses ---
  Permissions-Policy: accelerometer=(), autoplay=(), camera=(), display-capture=(), encrypted-media=(), fullscreen=(self), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), midi=(), payment=(), usb=(), interest-cohort=(), browsing-topics=()

  # --- Content Security Policy ---
  # Self-hosted assets only. Cloudflare Web Analytics beacon is allowed from
  # static.cloudflareinsights.com. Supabase REST is allowed for the beta
  # waitlist POST. All page scripts are EXTERNAL files (app.js, beta.js) — no
  # inline <script>, so script-src needs no 'unsafe-inline'. 'unsafe-inline' on
  # style-src covers the inline <style> theme bootstrap on the legal/beta pages.
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self' https://cdhrnjeegdhlrazbmpox.supabase.co; img-src 'self' data:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' https://static.cloudflareinsights.com; connect-src 'self' https://cdhrnjeegdhlrazbmpox.supabase.co https://cloudflareinsights.com https://static.cloudflareinsights.com; upgrade-insecure-requests

# Long-cache immutable static assets (hashed/versioned URLs)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts: long cache + CORS so they can be reused across subdomains if needed
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
